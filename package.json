{
  "name": "my-netlify-site",
  "version": "1.0.0",
  "description": "A dynamic site with Eleventy and Netlify.",
  "main": ".eleventy.js",
  "scripts": {
    "start": "eleventy --serve",
    "clean": "node -e \"require('fs').rmSync('_site', { recursive: true, force: true })\"",
    "audit:monitoring": "node scripts/audit-monitoring-coverage.mjs",
    "build": "npm run clean && npm run audit:monitoring && eleventy"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "rimraf": "^6.1.2"
  }
}
